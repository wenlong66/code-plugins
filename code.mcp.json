{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "fetch": {
      "args": [
        "-m",
        "mcp_server_fetch"
      ],
      "command": "python",
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "E:/work"
      ],
      "command": "npx"
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp",
        "--browser",
        "chrome"
      ],
      "command": "npx"
    },
    "godot": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "@coding-solo/godot-mcp"
      ],
      "env": {
        "GODOT_PATH": "D:/Program Files/Godot",
        "DEBUG": "true"
      }
    },
    "unityMCP": {
      "type": "http",
      "url": "http://localhost:8080/mcp"
    }
  }
}
